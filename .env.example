# Optional: custom user agent for Reddit requests
REDDIT_USER_AGENT=moon-or-doom/1.0

# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Subreddit to analyze (without r/ prefix)
SUBREDDIT=ASTSpaceMobile

# Profile weights: JSON mapping of Reddit usernames to importance (0-1).
# General public gets (1 - sum). Example gives general public 0.5.
# PROFILE_WEIGHTS={"expert_user": 0.3, "insider_dev": 0.2}
PROFILE_WEIGHTS={"CatSE": 0.4, "apan-man": 0.4}
